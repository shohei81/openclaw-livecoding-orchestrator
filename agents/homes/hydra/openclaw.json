{
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": { "primary": "google/gemini-2.5-flash" },
      "models": { "google/gemini-2.5-flash": {} },
      "skipBootstrap": true
    },
    "list": [
      { "id": "main", "identity": { "name": "Hydra", "theme": "Hydra visuals agent", "emoji": "🌀" } }
    ]
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": { "mode": "token" }
  },
  "messages": { "visibleReplies": "automatic" }
}
