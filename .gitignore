.env
node_modules/
session/*/
!session/.gitkeep
.DS_Store
third_party/

# OpenClaw writes a lot of runtime state inside each agent home; only the
# config and workspace are meant to be tracked.
agents/homes/*/*
!agents/homes/*/openclaw.json
!agents/homes/*/workspace/
agents/homes/*/openclaw.json.bak
agents/homes/*/openclaw.json.last-good
