# Which model the agents call. Pick ONE — the matching provider's API key
# must be set below. Built-in catalogs cover OpenAI / Anthropic / Google;
# NVIDIA NIM models are registered explicitly in agents/homes/*/openclaw.json.
#
# Supported defaults (any model the provider exposes will also work):
#   google/gemini-2.5-flash          ← current default, fastest / cheapest
#   google/gemini-2.5-pro
#   openai/gpt-5.5
#   anthropic/claude-sonnet-4-6
#   nvidia/meta/llama-3.3-70b-instruct
#   nvidia/nvidia/nemotron-3-super-120b-a12b
LLM_MODEL=google/gemini-2.5-flash

# Provider API keys. Fill ONLY the one matching LLM_MODEL above; others can
# stay blank. The container will only consume the key it actually needs.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# OpenClaw thinking level. Gemini 2.5 Flash, Kimi K2.6, and NVIDIA Nemotron
# all require "off" (they don't expose other thinking levels). Most OpenAI
# and Anthropic models accept "low" / "medium" / "high".
OPENCLAW_THINKING=off

# Session
SESSION_ID=session-001
BPM=110
BEATS_PER_BAR=4

# How often each agent regenerates its part, in bars. Higher = fewer LLM
# requests but slower musical evolution. 16 bars at 110bpm ≈ 35s per agent.
EDIT_EVERY_N_BARS=16

# Ports (host)
LIVECODING_HOST_PORT=8080
VALIDATOR_PORT=8081
REDIS_PORT=6379
